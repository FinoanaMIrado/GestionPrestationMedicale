  <property name="styleSheet">
   <string notr="true">/* ======== Fenêtre principale ======== */
QMainWindow {
    background-color: #f4f6f9;
    font-family: 'Segoe UI', sans-serif;
    font-size: 10pt;
}

QLabel#label {
    /* Couleur de texte foncée */
    color: #003366; 
    /* Taille et poids de police pour le titre */
    font-size: 24px;
    font-weight: bold;
    /* Aligner au centre */
    text-align: center;
    /* Marge supérieure pour l'espacement */
    margin-top: 10px;
}


/* ======== QTabWidget ======== */
QTabWidget::pane {
    border: 2px solid #0078d7;
    border-radius: 6px;
    background: white;
}

QTabBar::tab {
    background: #e1e9f0;
    color: #333;
    padding: 6px 20px;
    margin: 2px;
    border-radius: 6px;
    font-weight: 500;
}

QTabBar::tab:selected {
    background: #0078d7;
    color: white;
}

QTabBar::tab:hover {
    background: #5aa3f1;
    color: white;
}

/* ======== QPushButton ======== */
QPushButton {
    background-color: #0078d7;
    color: white;
    border-radius: 6px;
    padding: 6px 15px;
    border: none;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #1591ff;
}

QPushButton:pressed {
    background-color: #005a9e;
}

QPushButton:disabled {
    background-color: #cccccc;
    color: #666666;
}

/* ======== QLineEdit ======== */
QLineEdit {
    background-color: #ffffff;
    border: 1px solid #c0c0c0;
    border-radius: 4px;
    padding: 4px 6px;
}

QLineEdit:focus {
    border: 1px solid #0078d7;
    background-color: #f0f8ff;
}

/* ======== QLabel ======== */
QLabel {
    color: #333333;
    font-weight: 500;
}

/* ======== QTableWidget ======== */
QTableWidget {
    background-color: #ffffff;
    gridline-color: #cccccc;
    border: 1px solid #dddddd;
    border-radius: 4px;
}

QHeaderView::section {
    background-color: #0078d7;
    color: white;
    padding: 6px;
    border: none;
    font-weight: bold;
}

QTableWidget::item:selected {
    background-color: #e0f0ff;
    color: #000000;
}

/* ======== QGroupBox ======== */
QGroupBox {
    border: 1px solid #0078d7;
    border-radius: 6px;
    margin-top: 10px;
    padding: 10px;
    font-weight: bold;
    color: #0078d7;
}

QGroupBox:title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 4px;
}

/* ======== QComboBox ======== */
QComboBox {
    background-color: white;
    border: 1px solid #c0c0c0;
    border-radius: 4px;
    padding: 4px 6px;
}

QComboBox:hover {
    border: 1px solid #0078d7;
}

QComboBox QAbstractItemView {
    background-color: white;
    border: 1px solid #0078d7;
    selection-background-color: #0078d7;
    selection-color: white;
}

/* ======== QSpinBox ======== */
QSpinBox {
    background-color: white;
    border: 1px solid #c0c0c0;
    border-radius: 4px;
    padding: 2px 6px;
}

QSpinBox:focus {
    border: 1px solid #0078d7;
    background-color: #f0f8ff;
}

/* ======== QScrollArea ======== */
QScrollArea {
    background: transparent;
    border: none;
}

/* ======== QStatusBar ======== */
QStatusBar {
    background: #e1e9f0;
    color: #333;
    border-top: 1px solid #cccccc;
}
</string>
