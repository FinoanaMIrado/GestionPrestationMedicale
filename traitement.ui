  <property name="styleSheet">
   <string notr="true">/* ======================================= */
/* === GLOBAL &amp; FENÊTRE PRINCIPALE (1) === */
/* ======================================= */

QWidget {
    background-color: #f0f8ff; /* Bleu très pâle */
    color: #333333;
    font-family: &quot;Arial&quot;, sans-serif;
    font-size: 10pt;
}

/* Titre Principal */
QLabel#titleLabel {
    color: #004c8c;
    font-size: 16pt;
    font-weight: bold;
    padding: 10px;
    background-color: transparent;
}

/* Conteneur Principal Blanc */
QFrame#mainContentFrame {
    background-color: #ffffff;
    border: 1px solid #cccccc;
    border-radius: 5px;
}


/* ======================================= */
/* === BOUTONS D'ACTION &amp; NAVIGATION === */
/* ======================================= */

/* Boutons Primaires (Style Général par défaut) */
QPushButton {
    background-color: #007bff;
    color: white;
    border: none;
    padding: 10px 15px;
    border-radius: 3px;
    font-weight: bold;
    min-width: 100px;
}

QPushButton:hover {
    background-color: #0056b3;
}

/* Ciblage des Boutons Spécifiques */
QPushButton#Ajouter { /* Bouton Ajouter du formulaire médecin */
    min-width: 80px; 
}

QPushButton#AnulerMed, QPushButton#listButton { /* Boutons Secondaires/Annuler */
    background-color: transparent;
    color: #004c8c;
    border: 1px solid #004c8c;
    padding: 9px 15px;
    min-width: 80px;
}

QPushButton#AnulerMed:hover, QPushButton#listButton:hover {
    background-color: #e0f2ff;
}


/* ======================================= */
/* === ÉLÉMENTS DE FORMULAIRE (MEDECIN) === */
/* ======================================= */

/* Titre de Sous-fenêtre */
QLabel#subTitleLabel {
    color: #004c8c;
    font-size: 14pt;
    font-weight: 600;
    padding: 15px 0;
    background-color: transparent;
}

/* Labels Spécifiques */
QLabel#NomMed,
QLabel#NumeroMed,
QLabel#TauxJournalierMed {
    background-color: transparent;
    color: #333333;
    font-weight: 500;
    padding-right: 10px;
}

/* Champs de Saisie Spécifiques */
QLineEdit#formNomMed,
QLineEdit#formNumeroMed,
QLineEdit#formTauxMed {
    background-color: #ffffff;
    border: 1px solid #cccccc;
    padding: 5px;
    border-radius: 3px;
    color: #333333;
    min-height: 25px;
}

QLineEdit#formNomMed:focus,
QLineEdit#formNumeroMed:focus,
QLineEdit#formTauxMed:focus {
    border: 1px solid #007bff;
}

/* Styles pour les QLineEdit Génériques et QSpinBox si non nommés */
QLineEdit, QSpinBox, QDateEdit {
    border: 1px solid #cccccc;
    padding: 5px;
    border-radius: 3px;
}</string>
